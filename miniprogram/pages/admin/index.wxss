.admin-hero {
  position: relative;
  margin-bottom: 18rpx;
  padding: 26rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #163B72, #1677FF);
  border-radius: 22rpx;
  box-shadow: 0 8rpx 24rpx rgba(22, 82, 160, 0.18);
}

.admin-title {
  font-size: 34rpx;
  font-weight: 700;
}

.admin-desc {
  margin-top: 7rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
}

.admin-total {
  position: absolute;
  top: 30rpx;
  right: 24rpx;
  font-size: 21rpx;
}

.admin-mode-tabs {
  display: flex;
  margin-bottom: 16rpx;
  padding: 6rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
}

.admin-mode-tab {
  height: 62rpx;
  flex: 1;
  color: #86909C;
  border-radius: 12rpx;
  font-size: 23rpx;
  line-height: 62rpx;
  text-align: center;
}

.admin-mode-tab.active {
  color: #FFFFFF;
  background: #1677FF;
  font-weight: 600;
}

.status-tabs {
  display: flex;
  margin-bottom: 16rpx;
  padding: 6rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
}

.status-tab {
  height: 58rpx;
  flex: 1;
  color: #86909C;
  border-radius: 12rpx;
  font-size: 22rpx;
  line-height: 58rpx;
  text-align: center;
}

.status-tab.active {
  color: #1677FF;
  background: #E8F3FF;
  font-weight: 600;
}

.feedback-item {
  padding: 22rpx;
}

.feedback-meta {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.feedback-user {
  font-size: 26rpx;
  font-weight: 600;
}

.feedback-id,
.feedback-time {
  margin-top: 5rpx;
  color: #86909C;
  font-size: 19rpx;
}

.feedback-status {
  padding: 5rpx 10rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
}

.status-pending {
  color: #D46B08;
  background: #FFF7E6;
}

.status-resolved {
  color: #389E0D;
  background: #F6FFED;
}

.feedback-content {
  margin-top: 14rpx;
  color: #1D2129;
  font-size: 23rpx;
  line-height: 1.65;
}

.feedback-reply {
  margin-top: 12rpx;
  padding: 12rpx;
  color: #35506B;
  background: #F0F7FF;
  border-radius: 9rpx;
  font-size: 21rpx;
}

.member-actions {
  display: flex;
  margin-top: 16rpx;
  flex-wrap: wrap;
  gap: 10rpx;
}

.member-actions button {
  height: 54rpx;
  margin: 0;
  padding: 0 14rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  line-height: 54rpx;
}

.role-btn {
  color: #1677FF;
  background: #E8F3FF;
}

.role-btn.svip {
  color: #7A4B00;
  background: #FFE7B0;
}

.role-btn.admin {
  color: #FFFFFF;
  background: #354A67;
}

.reply-btn {
  margin-left: auto !important;
  color: #FFFFFF;
  background: #1677FF;
}

.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 22rpx;
}

.pagination button {
  height: 58rpx;
  margin: 0;
  padding: 0 22rpx;
  font-size: 21rpx;
  line-height: 58rpx;
}

.denied-card {
  color: #F53F3F;
  text-align: center;
}

.rbac-create-card,
.rbac-item {
  padding: 22rpx;
}

.rbac-section-title {
  margin-bottom: 14rpx;
  font-size: 27rpx;
  font-weight: 700;
}

.rbac-form-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.rbac-form-grid input,
.rbac-input {
  height: 64rpx;
  padding: 0 14rpx;
  background: #F6F8FB;
  border: 1rpx solid #E5EAF0;
  border-radius: 10rpx;
  font-size: 21rpx;
}

.rbac-form-grid input {
  width: calc(50% - 5rpx);
}

.rbac-form-grid input.wide {
  width: 100%;
}

.rbac-create-btn,
.rbac-save-btn {
  height: 58rpx;
  margin-top: 14rpx;
  color: #FFFFFF;
  background: #1677FF;
  border-radius: 11rpx;
  font-size: 22rpx;
  line-height: 58rpx;
}

.rbac-item-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.rbac-code {
  color: #1D2129;
  font-size: 26rpx;
  font-weight: 700;
}

.rbac-kind {
  margin-top: 3rpx;
  color: #86909C;
  font-size: 19rpx;
}

.rbac-input {
  width: 100%;
  margin-top: 9rpx;
}

.rank-input {
  width: 220rpx;
}

.binding-title {
  margin-top: 16rpx;
  color: #4E5969;
  font-size: 21rpx;
}

.permission-chips {
  display: flex;
  margin-top: 10rpx;
  flex-wrap: wrap;
  gap: 9rpx;
}

.permission-chip {
  padding: 8rpx 12rpx;
  color: #86909C;
  background: #F2F3F5;
  border: 1rpx solid #E5E6EB;
  border-radius: 999rpx;
  font-size: 19rpx;
}

.permission-chip.bound {
  color: #1677FF;
  background: #E8F3FF;
  border-color: #A9D4FF;
  font-weight: 600;
}
