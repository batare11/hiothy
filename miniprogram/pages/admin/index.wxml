<view class="page admin-page">
  <view class="admin-mode-tabs">
    <view
      class="admin-mode-tab {{adminMode === 'feedback' ? 'active' : ''}}"
      data-mode="feedback"
      bindtap="changeAdminMode"
    >
      <text class="mode-tab-icon">✉</text>
      <text>反馈管理</text>
    </view>
    <view
      class="admin-mode-tab {{adminMode === 'rbac' ? 'active' : ''}}"
      data-mode="rbac"
      bindtap="changeAdminMode"
    >
      <text class="mode-tab-icon">◆</text>
      <text>权限配置</text>
    </view>
  </view>

  <view wx:if="{{accessDenied}}" class="card denied-card">
    当前账号没有管理员权限
  </view>

  <block wx:elif="{{adminMode === 'feedback'}}">
    <view class="status-tabs">
      <view
        wx:for="{{statusOptions}}"
        wx:key="value"
        class="status-tab {{status === item.value ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="changeStatus"
      >{{item.label}}</view>
    </view>

    <view wx:if="{{loading}}" class="loading">反馈加载中...</view>
    <view wx:elif="{{!items.length}}" class="card empty-state">暂无反馈</view>

    <view wx:for="{{items}}" wx:key="id" class="card feedback-item">
      <view class="feedback-meta">
        <view>
          <view class="feedback-user">{{item.nickname}}</view>
          <view class="feedback-id">档案 ID：{{item.user_id}}</view>
        </view>
        <view class="feedback-status status-{{item.status}}">{{item.statusText}}</view>
      </view>
      <view class="feedback-time">{{item.displayTime}}</view>
      <view class="feedback-content">
        {{item.content}}
      </view>
      <view wx:if="{{item.conversationMessages.length}}" class="admin-conversation">
        <view
          wx:for="{{item.conversationMessages}}"
          wx:key="id"
          wx:for-item="message"
          class="admin-message {{message.sender_type === 'admin' ? 'admin' : 'user'}}"
        >
          <view class="admin-message-head">
            <text>{{message.sender_type === "admin" ? "管理员" : "用户"}}</text>
            <text>{{message.displayTime}}</text>
          </view>
          <view class="admin-message-content">{{message.content}}</view>
          <button
            wx:if="{{message.sender_type === 'admin' && message.can_revoke}}"
            class="message-revoke-btn"
            data-id="{{item.id}}"
            data-message-id="{{message.id}}"
            loading="{{revokingReplyId === message.id}}"
            bindtap="revokeFeedbackReply"
          >撤销此回复</button>
        </view>
      </view>
      <view class="member-actions">
        <button
          class="feedback-delete-btn"
          data-id="{{item.id}}"
          loading="{{deletingFeedbackId === item.id}}"
          bindtap="deleteFeedback"
        >删除</button>
        <button
          class="reply-btn"
          data-id="{{item.id}}"
          loading="{{replyingId === item.id}}"
          bindtap="replyFeedback"
        >回复</button>
      </view>
    </view>

    <view wx:if="{{totalPages > 1}}" class="pagination">
      <button disabled="{{page <= 1}}" bindtap="previousPage">上一页</button>
      <text>{{page}} / {{totalPages}}</text>
      <button disabled="{{page >= totalPages}}" bindtap="nextPage">下一页</button>
    </view>
  </block>

  <block wx:else>
    <view wx:if="{{rbacLoading}}" class="loading">权限配置加载中...</view>

    <block wx:else>
      <view class="rbac-sections">
      <view class="rbac-section role-management-section">
      <view class="rbac-zone-heading role-zone-heading">
        <view class="rbac-zone-index">3</view>
        <view class="rbac-zone-content">
          <view class="rbac-zone-title">角色管理</view>
          <view class="rbac-zone-desc">创建角色并维护名称、优先级和启用状态</view>
        </view>
        <button class="zone-add-btn role-add-btn" bindtap="openRoleCreate">新增角色</button>
      </view>

      <view
        wx:for="{{roles}}"
        wx:key="code"
        wx:for-item="role"
        wx:for-index="roleIndex"
        class="card rbac-item"
      >
        <view class="rbac-item-heading">
          <view>
            <view class="rbac-summary-name">{{role.name}}</view>
            <view class="rbac-kind">角色编码：{{role.code}}</view>
          </view>
          <view class="rbac-summary-actions">
            <view class="rbac-enabled">
              <text>启用</text>
              <switch
                checked="{{role.enabled}}"
                data-scope="roles"
                data-index="{{roleIndex}}"
                bindchange="handleRbacEnabled"
                color="#1677FF"
              />
            </view>
            <view
              class="rbac-expand-btn {{role.expanded ? 'expanded' : ''}}"
              data-scope="roles"
              data-index="{{roleIndex}}"
              bindtap="toggleRbacItem"
            >⌄</view>
          </view>
        </view>
        <view wx:if="{{role.expanded}}" class="rbac-edit-panel">
          <view class="rbac-field">
            <view class="rbac-field-label">角色名称</view>
            <input
              class="rbac-input"
              value="{{role.name}}"
              data-scope="roles"
              data-index="{{roleIndex}}"
              data-field="name"
              bindinput="handleRbacInput"
              placeholder="角色名称"
            />
          </view>
          <view class="rbac-field">
            <view class="rbac-field-label">角色说明</view>
            <input
              class="rbac-input"
              value="{{role.description}}"
              data-scope="roles"
              data-index="{{roleIndex}}"
              data-field="description"
              bindinput="handleRbacInput"
              placeholder="角色说明"
            />
          </view>
          <view class="rbac-field">
            <view class="rbac-field-label">角色优先级</view>
            <input
              class="rbac-input rank-input"
              type="number"
              value="{{role.rank}}"
              data-scope="roles"
              data-index="{{roleIndex}}"
              data-field="rank"
              bindinput="handleRbacInput"
              placeholder="展示优先级"
            />
          </view>
          <button
            class="rbac-save-btn"
            data-index="{{roleIndex}}"
            bindtap="saveRole"
          >更新该角色</button>
        </view>
      </view>
      </view>

      <view class="rbac-section permission-management-section">
      <view class="rbac-zone-heading permission-zone-heading">
        <view class="rbac-zone-index">4</view>
        <view class="rbac-zone-content">
          <view class="rbac-zone-title">功能权限管理</view>
          <view class="rbac-zone-desc">维护功能编码、所属模块和启用状态</view>
        </view>
        <button
          class="zone-add-btn permission-add-btn"
          bindtap="openPermissionCreate"
        >新增权限</button>
      </view>

      <view
        wx:for="{{permissions}}"
        wx:key="code"
        wx:for-item="permission"
        wx:for-index="permissionIndex"
        class="card rbac-item"
      >
        <view class="rbac-item-heading">
          <view>
            <view class="rbac-summary-name">{{permission.name}}</view>
            <view class="rbac-kind">权限编码：{{permission.code}}</view>
          </view>
          <view class="rbac-summary-actions">
            <view class="rbac-enabled">
              <text>启用</text>
              <switch
                checked="{{permission.enabled}}"
                data-scope="permissions"
                data-index="{{permissionIndex}}"
                bindchange="handleRbacEnabled"
                color="#1677FF"
              />
            </view>
            <view
              class="rbac-expand-btn {{permission.expanded ? 'expanded' : ''}}"
              data-scope="permissions"
              data-index="{{permissionIndex}}"
              bindtap="toggleRbacItem"
            >⌄</view>
          </view>
        </view>
        <view wx:if="{{permission.expanded}}" class="rbac-edit-panel">
          <view class="rbac-field">
            <view class="rbac-field-label">权限名称</view>
            <input
              class="rbac-input"
              value="{{permission.name}}"
              data-scope="permissions"
              data-index="{{permissionIndex}}"
              data-field="name"
              bindinput="handleRbacInput"
              placeholder="权限名称"
            />
          </view>
          <view class="rbac-field">
            <view class="rbac-field-label">所属模块</view>
            <input
              class="rbac-input"
              value="{{permission.module}}"
              data-scope="permissions"
              data-index="{{permissionIndex}}"
              data-field="module"
              bindinput="handleRbacInput"
              placeholder="所属模块"
            />
          </view>
          <view class="rbac-field">
            <view class="rbac-field-label">权限说明</view>
            <input
              class="rbac-input"
              value="{{permission.description}}"
              data-scope="permissions"
              data-index="{{permissionIndex}}"
              data-field="description"
              bindinput="handleRbacInput"
              placeholder="权限说明"
            />
          </view>
          <button
            class="rbac-save-btn"
            data-index="{{permissionIndex}}"
            bindtap="savePermission"
          >更新该功能</button>
        </view>
      </view>
      </view>

      <view class="rbac-section role-binding-section">
      <view class="rbac-zone-heading binding-zone-heading">
        <view class="rbac-zone-index">1</view>
        <view>
          <view class="rbac-zone-title">角色权限分配</view>
          <view class="rbac-zone-desc">蓝色表示已绑定，点击功能标签即可绑定或解绑</view>
        </view>
      </view>

      <view
        wx:for="{{permissionAssignableRoles}}"
        wx:key="code"
        wx:for-item="role"
        class="card binding-card"
      >
        <view class="binding-role-heading">
          <view>
            <view class="binding-role-name">{{role.name}}</view>
            <view class="binding-role-code">{{role.code}}</view>
          </view>
          <view class="binding-count">
            已绑定 {{role.permission_codes.length}} 项
          </view>
        </view>
        <view class="permission-chips">
          <view
            wx:for="{{role.permissionItems}}"
            wx:key="code"
            wx:for-item="permission"
            class="permission-chip {{permission.bound ? 'bound' : ''}}"
            data-role="{{role.code}}"
            data-permission="{{permission.code}}"
            data-bound="{{permission.bound}}"
            bindtap="toggleRolePermission"
          >
            <text class="permission-chip-state">{{permission.bound ? "✓" : "＋"}}</text>
            {{permission.name}}
          </view>
        </view>
        <view wx:if="{{!role.permissionItems.length}}" class="binding-empty">
          暂无可分配的功能权限
        </view>
      </view>
      <view wx:if="{{!permissionAssignableRoles.length}}" class="card binding-empty-card">
        暂无启用中的角色，请先在角色管理中启用角色
      </view>
      </view>

      <view class="rbac-section user-grant-section">
      <view class="rbac-zone-heading user-grant-zone-heading">
        <view class="rbac-zone-index">2</view>
        <view class="rbac-zone-content">
          <view class="rbac-zone-title">用户角色授权</view>
          <view class="rbac-zone-desc">通过健康档案 ID 为用户分配角色</view>
        </view>
      </view>

      <view class="card user-grant-card">
        <view class="dialog-label">健康档案 ID</view>
        <input
          class="rbac-input grant-user-input"
          value="{{userGrant.archiveId}}"
          data-scope="userGrant"
          data-field="archiveId"
          bindinput="handleRbacInput"
          placeholder="请输入用户的 12 位健康档案 ID"
        />
        <view class="dialog-label grant-role-label">选择角色</view>
        <picker
          range="{{assignableRoles}}"
          range-key="name"
          bindchange="changeGrantRole"
        >
          <view class="grant-role-picker">
            {{userGrant.roleName || "请选择需要授予的角色"}}
          </view>
        </picker>
        <button class="rbac-save-btn" bindtap="grantUserRole">确认授权</button>
      </view>
      </view>
      </view>
    </block>
  </block>

  <view
    wx:if="{{roleCreateVisible}}"
    class="modal-mask"
    bindtap="closeRoleCreate"
  >
    <view class="role-create-dialog" catchtap="preventModalClose">
      <view class="dialog-title">新增角色</view>
      <view class="dialog-desc">创建后可在“角色权限分配”中配置功能权限</view>
      <view class="dialog-field">
        <view class="dialog-label">角色编码</view>
        <input
          value="{{newRole.code}}"
          data-scope="newRole"
          data-field="code"
          bindinput="handleRbacInput"
          placeholder="如 doctor，仅限小写字母、数字和下划线"
        />
      </view>
      <view class="dialog-field">
        <view class="dialog-label">角色名称</view>
        <input
          value="{{newRole.name}}"
          data-scope="newRole"
          data-field="name"
          bindinput="handleRbacInput"
          placeholder="请输入角色名称"
        />
      </view>
      <view class="dialog-field">
        <view class="dialog-label">角色说明</view>
        <input
          value="{{newRole.description}}"
          data-scope="newRole"
          data-field="description"
          bindinput="handleRbacInput"
          placeholder="简要描述该角色用途"
        />
      </view>
      <view class="dialog-field">
        <view class="dialog-label">角色优先级</view>
        <input
          value="{{newRole.rank}}"
          type="number"
          data-scope="newRole"
          data-field="rank"
          bindinput="handleRbacInput"
          placeholder="默认 0"
        />
        <view class="rank-help">数值越大，用户同时拥有多个角色时越优先展示；默认填 0。</view>
      </view>
      <view class="dialog-actions">
        <button class="dialog-cancel-btn" bindtap="closeRoleCreate">返回</button>
        <button class="dialog-confirm-btn" bindtap="createRole">确认创建</button>
      </view>
    </view>
  </view>

  <view
    wx:if="{{permissionCreateVisible}}"
    class="modal-mask"
    bindtap="closePermissionCreate"
  >
    <view class="role-create-dialog" catchtap="preventModalClose">
      <view class="dialog-title">新增功能权限</view>
      <view class="dialog-desc">创建后可在“角色权限分配”中绑定给不同角色</view>
      <view class="dialog-field">
        <view class="dialog-label">权限编码</view>
        <input
          value="{{newPermission.code}}"
          data-scope="newPermission"
          data-field="code"
          bindinput="handleRbacInput"
          placeholder="如 report_export，仅限小写字母、数字和下划线"
        />
      </view>
      <view class="dialog-field">
        <view class="dialog-label">权限名称</view>
        <input
          value="{{newPermission.name}}"
          data-scope="newPermission"
          data-field="name"
          bindinput="handleRbacInput"
          placeholder="请输入功能权限名称"
        />
      </view>
      <view class="dialog-field">
        <view class="dialog-label">所属模块</view>
        <input
          value="{{newPermission.module}}"
          data-scope="newPermission"
          data-field="module"
          bindinput="handleRbacInput"
          placeholder="如 ocr、archive、admin"
        />
        <view class="rank-help">用于对功能权限进行分类展示，不影响实际鉴权。</view>
      </view>
      <view class="dialog-field">
        <view class="dialog-label">权限说明</view>
        <input
          value="{{newPermission.description}}"
          data-scope="newPermission"
          data-field="description"
          bindinput="handleRbacInput"
          placeholder="简要描述该功能权限用途"
        />
      </view>
      <view class="dialog-actions">
        <button class="dialog-cancel-btn" bindtap="closePermissionCreate">返回</button>
        <button class="dialog-confirm-btn" bindtap="createPermission">确认创建</button>
      </view>
    </view>
  </view>
</view>
