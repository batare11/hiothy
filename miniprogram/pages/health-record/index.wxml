<view class="page">
  <view class="archive-hero">
    <view class="archive-title">就诊资料</view>
    <view class="archive-desc">
      生成结构化健康摘要，可复制后发送给医生或家人
    </view>
    <view class="hero-action-row">
      <button class="hero-export-btn" bindtap="copyMedicalSummary">生成静态信息</button>
      <button
        class="hero-ai-btn"
        loading="{{aiReportLoading}}"
        bindtap="generateAiHealthReport"
      >AI 智能分析</button>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">健康档案加载中...</view>

  <block wx:else>
    <view class="stats-grid">
      <view class="stat-card">
        <view class="stat-value">{{overview.record_days || 0}}</view>
        <view class="stat-label">累计记录天数</view>
      </view>
      <view class="stat-card">
        <view class="stat-value">{{overview.total || 0}}</view>
        <view class="stat-label">累计记录次数</view>
      </view>
      <view class="stat-card">
        <view class="stat-value normal-value">{{overview.normal_rate || 0}}%</view>
        <view class="stat-label">指标正常率</view>
      </view>
      <view class="stat-card">
        <view class="stat-value warning-value">{{overview.abnormal_rate || 0}}%</view>
        <view class="stat-label">指标异常率</view>
      </view>
    </view>

    <view class="card latest-card">
      <view class="card-heading">
        <view>
          <view class="section-title">最近一次测量</view>
          <view class="section-desc">{{overview.latestTime || "暂无测量记录"}}</view>
        </view>
        <view wx:if="{{overview.latest}}" class="latest-status-group">
          <view class="latest-status status-{{overview.latest.status}}">
            {{overview.latest.status_text}}
          </view>
          <view
            wx:if="{{bmi.value}}"
            class="latest-status bmi-status bmi-status-{{bmi.status}}"
          >{{bmi.label}}</view>
        </view>
      </view>
      <view wx:if="{{overview.latest}}" class="latest-values">
        <view class="latest-reading">
          <view class="latest-main">
            <text class="latest-pressure">{{overview.latest.systolic}}/{{overview.latest.diastolic}}</text>
            <text class="latest-unit">mmHg</text>
          </view>
          <view class="latest-heart">心率 {{overview.latest.heart_rate || "--"}} 次/分</view>
        </view>
        <view class="bmi-summary">
          <text class="bmi-label">BMI</text>
          <text class="bmi-value">{{bmi.value || "--"}}</text>
        </view>
      </view>
      <view wx:else class="empty-state">
        <view>还没有血压记录</view>
        <view class="empty-bmi">
          BMI {{bmi.value || "--"}}
          <text class="bmi-status bmi-status-{{bmi.status}}">{{bmi.label}}</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="section-title">历史平均水平</view>
      <view class="average-row">
        <view class="average-item">
          <view class="average-value">{{overview.averages.systolic || "--"}}</view>
          <view class="average-label">平均高压</view>
        </view>
        <view class="average-item">
          <view class="average-value">{{overview.averages.diastolic || "--"}}</view>
          <view class="average-label">平均低压</view>
        </view>
        <view class="average-item">
          <view class="average-value">{{overview.averages.heart_rate || "--"}}</view>
          <view class="average-label">平均心率</view>
        </view>
      </view>
    </view>

    <view class="card archive-form-card">
      <view class="section-title">其他档案资料</view>
      <view class="section-desc">补充身体与生活习惯，方便形成更完整的就诊摘要</view>

      <view class="archive-form-grid compact-measures">
        <view class="archive-field">
          <view class="archive-label">年龄</view>
          <view class="number-input-wrap">
            <input
              class="archive-input"
              type="number"
              maxlength="3"
              value="{{archive.age}}"
              data-field="age"
              bindinput="handleArchiveInput"
              placeholder="请输入"
            />
            <text class="input-unit">岁</text>
          </view>
        </view>
        <view class="archive-field">
          <view class="archive-label">身高</view>
          <view class="number-input-wrap">
            <input
              class="archive-input"
              type="digit"
              value="{{archive.height_cm}}"
              data-field="height_cm"
              bindinput="handleArchiveInput"
              placeholder="请输入"
            />
            <text class="input-unit">cm</text>
          </view>
        </view>
        <view class="archive-field">
          <view class="archive-label">体重</view>
          <view class="number-input-wrap">
            <input
              class="archive-input"
              type="digit"
              value="{{archive.weight_jin}}"
              data-field="weight_jin"
              bindinput="handleArchiveInput"
              placeholder="请输入"
            />
            <text class="input-unit">斤</text>
          </view>
        </view>
      </view>

      <view class="binary-row">
        <view class="binary-group">
          <view class="archive-label">性别</view>
          <view class="binary-options">
            <view
              class="binary-option {{archive.gender == 1 ? 'selected' : ''}}"
              data-value="1"
              catchtap="selectGender"
            >男</view>
            <view
              class="binary-option {{archive.gender == 0 ? 'selected' : ''}}"
              data-value="0"
              catchtap="selectGender"
            >女</view>
          </view>
        </view>
        <view class="binary-group">
          <view class="archive-label">婚姻状态</view>
          <view class="binary-options">
            <view
              class="binary-option {{archive.marital_status == 1 ? 'selected' : ''}}"
              data-value="1"
              catchtap="selectMaritalStatus"
            >已婚</view>
            <view
              class="binary-option {{archive.marital_status == 0 ? 'selected' : ''}}"
              data-value="0"
              catchtap="selectMaritalStatus"
            >未婚</view>
          </view>
        </view>
      </view>

      <view class="habit-title">生活习惯</view>
      <view class="habit-grid">
        <view class="habit-item">
          <text>抽烟</text>
          <switch
            checked="{{archive.smoking}}"
            color="#1677FF"
            data-field="smoking"
            bindchange="changeHabit"
          />
        </view>
        <view class="habit-item">
          <text>喝酒</text>
          <switch
            checked="{{archive.drinking}}"
            color="#1677FF"
            data-field="drinking"
            bindchange="changeHabit"
          />
        </view>
        <view class="habit-item wide">
          <text>经常熬夜</text>
          <switch
            checked="{{archive.staying_up_late}}"
            color="#1677FF"
            data-field="staying_up_late"
            bindchange="changeHabit"
          />
        </view>
      </view>

      <view class="archive-label note-label">备注</view>
      <textarea
        class="archive-note"
        maxlength="1000"
        value="{{archive.note}}"
        data-field="note"
        bindinput="handleArchiveInput"
        placeholder="如慢性病、过敏史、长期服药、近期症状等"
      ></textarea>
      <view class="note-count">{{archive.note.length || 0}} / 1000</view>
      <button
        class="save-archive-btn"
        loading="{{savingArchive}}"
        bindtap="saveArchive"
      >保存辅助档案</button>
    </view>

    <view class="archive-notice">
      健康档案用于记录与趋势参考，不替代医生诊断。血压严重异常或身体不适时请及时就医。
    </view>
  </block>

  <view
    wx:if="{{aiReportVisible}}"
    class="ai-report-mask"
    bindtap="closeAiReport"
  >
    <view class="ai-report-modal" catchtap="preventModalClose">
      <view class="ai-report-header">
        <view>
          <view class="ai-report-title">AI 健康报告</view>
          <view class="ai-report-model">{{aiReportModel}}</view>
        </view>
        <view class="ai-report-close" bindtap="closeAiReport">×</view>
      </view>
      <scroll-view class="ai-report-scroll" scroll-y>
        <text class="ai-report-content" selectable>{{aiReport}}</text>
      </scroll-view>
      <view class="ai-report-notice">报告仅供健康管理参考，不作为医疗诊断依据</view>
      <button class="ai-report-copy" bindtap="copyAiReport">复制报告</button>
    </view>
  </view>
</view>
