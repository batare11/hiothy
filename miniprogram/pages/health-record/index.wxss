.archive-hero {
  position: relative;
  margin: 8rpx 0 24rpx;
  padding: 36rpx 32rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #0960D8, #58A5FF);
  border-radius: 24rpx;
}

.archive-title {
  font-size: 38rpx;
  font-weight: 600;
}

.archive-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 23rpx;
}

.archive-status {
  display: inline-flex;
  margin-top: 24rpx;
  padding: 10rpx 16rpx;
  align-items: center;
  background: rgba(255, 255, 255, 0.16);
  border-radius: 999rpx;
  font-size: 21rpx;
}

.status-light {
  width: 12rpx;
  height: 12rpx;
  margin-right: 9rpx;
  background: #95DE64;
  border-radius: 50%;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  padding: 28rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 22rpx rgba(22, 119, 255, 0.07);
}

.stat-value {
  color: #1677FF;
  font-size: 40rpx;
  font-weight: 600;
}

.normal-value {
  color: #52C41A;
}

.warning-value {
  color: #FA8C16;
}

.stat-label {
  margin-top: 8rpx;
  color: #86909C;
  font-size: 22rpx;
}

.card-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.latest-status {
  padding: 8rpx 14rpx;
  border-radius: 9rpx;
  font-size: 21rpx;
}

.status-normal {
  color: #389E0D;
  background: #F6FFED;
}

.status-warning {
  color: #D46B08;
  background: #FFF7E6;
}

.status-danger {
  color: #CF1322;
  background: #FFF1F0;
}

.latest-values {
  margin-top: 28rpx;
  padding: 26rpx;
  background: #E8F3FF;
  border-radius: 18rpx;
}

.latest-main {
  display: flex;
  align-items: baseline;
}

.latest-pressure {
  color: #0960D8;
  font-size: 54rpx;
  font-weight: 600;
}

.latest-unit {
  margin-left: 10rpx;
  color: #86909C;
  font-size: 21rpx;
}

.latest-heart {
  margin-top: 8rpx;
  color: #FA8C16;
}

.average-row {
  display: flex;
  margin-top: 24rpx;
}

.average-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #F2F3F5;
}

.average-item:last-child {
  border-right: 0;
}

.average-value {
  color: #1677FF;
  font-size: 34rpx;
  font-weight: 600;
}

.average-label {
  margin-top: 6rpx;
  color: #86909C;
  font-size: 20rpx;
}

.month-scroll {
  margin-top: 22rpx;
  white-space: nowrap;
}

.month-list {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.month-item {
  width: 220rpx;
  padding: 22rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
}

.month-name {
  color: #4E5969;
  font-size: 22rpx;
}

.month-pressure {
  margin-top: 12rpx;
  color: #1677FF;
  font-size: 32rpx;
  font-weight: 600;
}

.month-heart,
.month-count {
  margin-top: 7rpx;
  color: #86909C;
  font-size: 20rpx;
}

.month-count {
  color: #52C41A;
}

.export-btn {
  margin-top: 24rpx;
  color: #FFFFFF;
  background: #0960D8;
  border-radius: 14rpx;
}

.archive-notice {
  padding: 6rpx 20rpx 36rpx;
  color: #86909C;
  font-size: 21rpx;
  line-height: 1.7;
  text-align: center;
}
