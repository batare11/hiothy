.archive-hero {
  position: relative;
  margin: 4rpx 0 18rpx;
  padding: 24rpx 28rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #0960D8, #58A5FF);
  border-radius: 24rpx;
}

.archive-title {
  font-size: 34rpx;
  font-weight: 600;
}

.archive-desc {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 21rpx;
}

.hero-action-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.hero-export-btn,
.hero-ai-btn {
  display: flex;
  height: 64rpx;
  margin: 0;
  align-items: center;
  justify-content: center;
  flex: 1;
  border-radius: 14rpx;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 64rpx;
}

.hero-export-btn {
  color: #0960D8;
  background: #FFFFFF;
}

.hero-ai-btn {
  color: #FFFFFF;
  background: rgba(7, 49, 117, 0.42);
  border: 1rpx solid rgba(255, 255, 255, 0.55);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  padding: 28rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 22rpx rgba(22, 119, 255, 0.07);
}

.stat-value {
  color: #1677FF;
  font-size: 40rpx;
  font-weight: 600;
}

.normal-value {
  color: #52C41A;
}

.warning-value {
  color: #FA8C16;
}

.stat-label {
  margin-top: 8rpx;
  color: #86909C;
  font-size: 22rpx;
}

.card-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.latest-status {
  padding: 8rpx 14rpx;
  border-radius: 9rpx;
  font-size: 21rpx;
}

.latest-status-group {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.latest-status-group .bmi-status {
  margin-left: 0;
  padding: 8rpx 14rpx;
  font-size: 21rpx;
}

.status-normal {
  color: #389E0D;
  background: #F6FFED;
}

.status-low {
  color: #096DD9;
  background: #E6F7FF;
}

.status-elevated {
  color: #AD6800;
  background: #FFFBE6;
}

.status-warning {
  color: #D46B08;
  background: #FFF7E6;
}

.status-danger {
  color: #CF1322;
  background: #FFF1F0;
}

.latest-values {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-top: 28rpx;
  padding: 26rpx;
  background: #E8F3FF;
  border-radius: 18rpx;
}

.latest-reading {
  min-width: 0;
  flex: 1;
}

.latest-main {
  display: flex;
  align-items: baseline;
}

.latest-pressure {
  color: #0960D8;
  font-size: 54rpx;
  font-weight: 600;
}

.latest-unit {
  margin-left: 10rpx;
  color: #86909C;
  font-size: 21rpx;
}

.latest-heart {
  color: #FA8C16;
}

.bmi-summary {
  display: flex;
  min-width: 0;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-height: 72rpx;
  padding-left: 16rpx;
  border-left: 1rpx solid #C9E2FF;
  color: #4E5969;
  font-size: 23rpx;
}

.bmi-label {
  color: #86909C;
  font-size: 25rpx;
  font-weight: 500;
}

.bmi-value {
  margin-left: 10rpx;
  color: #1677FF;
  font-size: 42rpx;
  font-weight: 600;
}

.bmi-status {
  margin-left: 8rpx;
  padding: 3rpx 9rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.bmi-status-missing {
  color: #1677FF;
  background: #E8F3FF;
}

.bmi-status-low {
  color: #096DD9;
  background: #E6F7FF;
}

.bmi-status-normal {
  color: #389E0D;
  background: #F6FFED;
}

.bmi-status-elevated {
  color: #AD6800;
  background: #FFFBE6;
}

.bmi-status-danger {
  color: #CF1322;
  background: #FFF1F0;
}

.empty-bmi {
  margin-top: 14rpx;
  color: #4E5969;
  font-size: 22rpx;
}

.average-row {
  display: flex;
  margin-top: 24rpx;
}

.average-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #F2F3F5;
}

.average-item:last-child {
  border-right: 0;
}

.average-value {
  color: #1677FF;
  font-size: 34rpx;
  font-weight: 600;
}

.average-label {
  margin-top: 6rpx;
  color: #86909C;
  font-size: 20rpx;
}

.archive-form-card {
  padding-bottom: 30rpx;
}

.archive-form-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}

.archive-field {
  min-width: 0;
  padding: 14rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
}

.archive-label {
  color: #4E5969;
  font-size: 22rpx;
  font-weight: 500;
}

.number-input-wrap {
  display: flex;
  margin-top: 8rpx;
  align-items: center;
}

.archive-input {
  min-width: 0;
  flex: 1;
  color: #1D2129;
  font-size: 24rpx;
}

.input-unit {
  color: #86909C;
  font-size: 19rpx;
}

.binary-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.binary-group {
  min-width: 0;
  flex: 1;
}

.binary-options {
  display: flex;
  gap: 8rpx;
  margin-top: 9rpx;
}

.binary-option {
  display: flex;
  flex: 1;
  padding: 12rpx 4rpx;
  align-items: center;
  justify-content: center;
  color: #86909C;
  background: #F2F3F5;
  border: 1rpx solid transparent;
  border-radius: 10rpx;
  font-size: 21rpx;
  text-align: center;
}

.binary-option.selected {
  color: #1677FF;
  background: #E8F3FF;
  border-color: #91CAFF;
  font-weight: 600;
}

.habit-title {
  margin-top: 20rpx;
  color: #4E5969;
  font-size: 24rpx;
  font-weight: 500;
}

.habit-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 10rpx;
}

.habit-item {
  display: flex;
  min-height: 62rpx;
  padding: 0 10rpx;
  align-items: center;
  justify-content: space-between;
  color: #4E5969;
  background: #F7F8FA;
  border-radius: 14rpx;
  font-size: 20rpx;
}

.habit-item.wide {
  grid-column: auto;
}

.habit-item switch {
  transform: scale(0.78);
  transform-origin: right center;
}

.note-label {
  margin-top: 20rpx;
}

.archive-note {
  box-sizing: border-box;
  width: 100%;
  height: 112rpx;
  margin-top: 10rpx;
  padding: 16rpx;
  color: #1D2129;
  background: #F7F8FA;
  border-radius: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.note-count {
  margin-top: 8rpx;
  color: #A9B1BC;
  font-size: 20rpx;
  text-align: right;
}

.save-archive-btn {
  display: flex;
  height: 70rpx;
  margin-top: 14rpx;
  padding: 0;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #1677FF;
  border-radius: 14rpx;
  font-size: 26rpx;
  line-height: 1;
  text-align: center;
}

.archive-notice {
  padding: 6rpx 20rpx 36rpx;
  color: #86909C;
  font-size: 21rpx;
  line-height: 1.7;
  text-align: center;
}

.ai-report-mask {
  position: fixed;
  z-index: 1200;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  background: rgba(17, 24, 39, 0.68);
}

.ai-report-modal {
  display: flex;
  width: 100%;
  max-height: 88vh;
  padding: 28rpx;
  flex-direction: column;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.28);
}

.ai-report-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.ai-report-title {
  font-size: 32rpx;
  font-weight: 600;
}

.ai-report-model {
  margin-top: 4rpx;
  color: #86909C;
  font-size: 19rpx;
}

.ai-report-close {
  display: flex;
  width: 52rpx;
  height: 52rpx;
  align-items: center;
  justify-content: center;
  color: #86909C;
  background: #F2F3F5;
  border-radius: 50%;
  font-size: 34rpx;
}

.ai-report-scroll {
  height: 650rpx;
  margin-top: 20rpx;
  padding: 20rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
}

.ai-report-content {
  color: #303846;
  font-size: 23rpx;
  line-height: 1.8;
  white-space: pre-wrap;
}

.ai-report-notice {
  margin-top: 14rpx;
  color: #86909C;
  font-size: 19rpx;
  text-align: center;
}

.ai-report-copy {
  display: flex;
  height: 68rpx;
  margin: 16rpx 0 0;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #1677FF;
  border-radius: 14rpx;
  font-size: 24rpx;
  line-height: 68rpx;
}

.ai-loading-mask {
  position: fixed;
  z-index: 1300;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(17, 24, 39, 0.62);
}

.ai-loading-card {
  width: 100%;
  max-width: 540rpx;
  padding: 42rpx 30rpx 36rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.28);
  text-align: center;
}

.ai-loading-spinner {
  width: 64rpx;
  height: 64rpx;
  margin: 0 auto;
  border: 7rpx solid #D9EAFE;
  border-top-color: #1677FF;
  border-radius: 50%;
  animation: ai-loading-rotate 0.9s linear infinite;
}

.ai-loading-title {
  margin-top: 26rpx;
  color: #1D2129;
  font-size: 29rpx;
  font-weight: 600;
}

.ai-loading-desc {
  margin-top: 12rpx;
  color: #4E5969;
  font-size: 22rpx;
}

.ai-loading-tip {
  margin-top: 8rpx;
  color: #86909C;
  font-size: 19rpx;
}

@keyframes ai-loading-rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
