.archive-hero {
  position: relative;
  margin: 8rpx 0 24rpx;
  padding: 36rpx 32rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #0960D8, #58A5FF);
  border-radius: 24rpx;
}

.archive-title {
  font-size: 38rpx;
  font-weight: 600;
}

.archive-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 23rpx;
}

.hero-export-btn {
  display: flex;
  width: 100%;
  height: 76rpx;
  margin-top: 24rpx;
  align-items: center;
  justify-content: center;
  color: #0960D8;
  background: #FFFFFF;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 76rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  padding: 28rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 22rpx rgba(22, 119, 255, 0.07);
}

.stat-value {
  color: #1677FF;
  font-size: 40rpx;
  font-weight: 600;
}

.normal-value {
  color: #52C41A;
}

.warning-value {
  color: #FA8C16;
}

.stat-label {
  margin-top: 8rpx;
  color: #86909C;
  font-size: 22rpx;
}

.card-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.latest-status {
  padding: 8rpx 14rpx;
  border-radius: 9rpx;
  font-size: 21rpx;
}

.status-normal {
  color: #389E0D;
  background: #F6FFED;
}

.status-low {
  color: #096DD9;
  background: #E6F7FF;
}

.status-elevated {
  color: #AD6800;
  background: #FFFBE6;
}

.status-warning {
  color: #D46B08;
  background: #FFF7E6;
}

.status-danger {
  color: #CF1322;
  background: #FFF1F0;
}

.latest-values {
  margin-top: 28rpx;
  padding: 26rpx;
  background: #E8F3FF;
  border-radius: 18rpx;
}

.latest-main {
  display: flex;
  align-items: baseline;
}

.latest-pressure {
  color: #0960D8;
  font-size: 54rpx;
  font-weight: 600;
}

.latest-unit {
  margin-left: 10rpx;
  color: #86909C;
  font-size: 21rpx;
}

.latest-heart {
  margin-top: 8rpx;
  color: #FA8C16;
}

.average-row {
  display: flex;
  margin-top: 24rpx;
}

.average-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #F2F3F5;
}

.average-item:last-child {
  border-right: 0;
}

.average-value {
  color: #1677FF;
  font-size: 34rpx;
  font-weight: 600;
}

.average-label {
  margin-top: 6rpx;
  color: #86909C;
  font-size: 20rpx;
}

.archive-form-card {
  padding-bottom: 30rpx;
}

.archive-form-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}

.archive-field {
  min-width: 0;
  padding: 14rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
}

.archive-label {
  color: #4E5969;
  font-size: 22rpx;
  font-weight: 500;
}

.number-input-wrap {
  display: flex;
  margin-top: 8rpx;
  align-items: center;
}

.archive-input {
  min-width: 0;
  flex: 1;
  color: #1D2129;
  font-size: 24rpx;
}

.input-unit {
  color: #86909C;
  font-size: 19rpx;
}

.binary-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.binary-group {
  min-width: 0;
  flex: 1;
}

.binary-options {
  display: flex;
  gap: 8rpx;
  margin-top: 9rpx;
}

.binary-option {
  display: flex;
  flex: 1;
  padding: 12rpx 4rpx;
  align-items: center;
  justify-content: center;
  color: #86909C;
  background: #F2F3F5;
  border: 1rpx solid transparent;
  border-radius: 10rpx;
  font-size: 21rpx;
  text-align: center;
}

.binary-option.selected {
  color: #1677FF;
  background: #E8F3FF;
  border-color: #91CAFF;
  font-weight: 600;
}

.habit-title {
  margin-top: 20rpx;
  color: #4E5969;
  font-size: 24rpx;
  font-weight: 500;
}

.habit-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 10rpx;
}

.habit-item {
  display: flex;
  min-height: 62rpx;
  padding: 0 10rpx;
  align-items: center;
  justify-content: space-between;
  color: #4E5969;
  background: #F7F8FA;
  border-radius: 14rpx;
  font-size: 20rpx;
}

.habit-item.wide {
  grid-column: auto;
}

.habit-item switch {
  transform: scale(0.78);
  transform-origin: right center;
}

.note-label {
  margin-top: 20rpx;
}

.archive-note {
  box-sizing: border-box;
  width: 100%;
  height: 112rpx;
  margin-top: 10rpx;
  padding: 16rpx;
  color: #1D2129;
  background: #F7F8FA;
  border-radius: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.note-count {
  margin-top: 8rpx;
  color: #A9B1BC;
  font-size: 20rpx;
  text-align: right;
}

.save-archive-btn {
  display: flex;
  height: 70rpx;
  margin-top: 14rpx;
  padding: 0;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #1677FF;
  border-radius: 14rpx;
  font-size: 26rpx;
  line-height: 1;
  text-align: center;
}

.archive-notice {
  padding: 6rpx 20rpx 36rpx;
  color: #86909C;
  font-size: 21rpx;
  line-height: 1.7;
  text-align: center;
}
