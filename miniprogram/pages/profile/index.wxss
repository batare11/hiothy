.profile-hero {
  display: flex;
  align-items: center;
  margin: 4rpx 0 16rpx;
  padding: 22rpx 24rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #1677FF, #4598FF);
  border-radius: 24rpx;
}

.avatar-button {
  width: 88rpx;
  height: 88rpx;
  margin: 0;
  padding: 0;
  overflow: hidden;
  background: transparent;
  border-radius: 50%;
}

.avatar {
  display: flex;
  width: 88rpx;
  height: 88rpx;
  align-items: center;
  justify-content: center;
  color: #1677FF;
  background: #FFFFFF;
  border: 4rpx solid rgba(255, 255, 255, 0.55);
  border-radius: 50%;
  font-size: 34rpx;
  font-weight: 600;
}

.profile-main {
  min-width: 0;
  margin-left: 18rpx;
  flex: 1;
}

.profile-name {
  overflow: hidden;
  font-size: 30rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-id {
  margin-top: 5rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 21rpx;
}

.safe-tag {
  padding: 7rpx 12rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 999rpx;
  font-size: 19rpx;
}

.compact-card {
  margin-bottom: 16rpx;
  padding: 22rpx 24rpx;
}

.profile-row {
  display: flex;
  min-height: 76rpx;
  align-items: center;
  border-bottom: 1rpx solid #F2F3F5;
}

.row-label {
  color: #4E5969;
}

.row-input {
  margin-left: auto;
  text-align: right;
}

.row-value {
  color: #4E5969;
}

.profile-save {
  height: 70rpx;
  margin-top: 18rpx;
  font-size: 27rpx;
}

.feedback-heading,
.history-heading,
.history-item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-count {
  color: #86909C;
  font-size: 20rpx;
}

.feedback-input {
  width: 100%;
  height: 150rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  line-height: 1.6;
}

.contact-input {
  height: 68rpx;
  margin-top: 12rpx;
  padding: 0 16rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
}

.feedback-footer {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
}

.char-count {
  color: #C9CDD4;
  font-size: 21rpx;
}

.feedback-btn {
  height: 64rpx;
  margin: 0 0 0 auto;
  padding: 0 26rpx;
  color: #FFFFFF;
  background: #0960D8;
  border-radius: 14rpx;
  font-size: 24rpx;
  line-height: 64rpx;
}

.history-divider {
  margin: 20rpx 0 16rpx;
  border-top: 1rpx solid #F2F3F5;
}

.history-title {
  color: #1D2129;
  font-size: 26rpx;
  font-weight: 600;
}

.history-toggle {
  color: #1677FF;
  font-size: 21rpx;
}

.history-item {
  margin-top: 14rpx;
  padding: 16rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
}

.history-time {
  color: #86909C;
  font-size: 19rpx;
}

.history-status {
  padding: 5rpx 10rpx;
  border-radius: 7rpx;
  font-size: 18rpx;
}

.status-pending {
  color: #D46B08;
  background: #FFF7E6;
}

.status-processing {
  color: #1677FF;
  background: #E8F3FF;
}

.status-resolved {
  color: #389E0D;
  background: #F6FFED;
}

.history-content {
  display: -webkit-box;
  margin-top: 10rpx;
  overflow: hidden;
  color: #4E5969;
  font-size: 22rpx;
  line-height: 1.5;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.history-contact {
  margin-top: 8rpx;
  color: #A9B1BC;
  font-size: 19rpx;
}

.history-empty {
  padding: 28rpx 0 12rpx;
  color: #A9B1BC;
  font-size: 21rpx;
  text-align: center;
}

.health-notice {
  padding: 2rpx 18rpx 20rpx;
  color: #86909C;
  font-size: 21rpx;
  line-height: 1.7;
  text-align: center;
}
