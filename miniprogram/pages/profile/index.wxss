.profile-hero {
  position: relative;
  display: flex;
  align-items: center;
  margin: 4rpx 0 16rpx;
  padding: 16rpx 20rpx;
  overflow: hidden;
  color: #FFFFFF;
  background:
    radial-gradient(circle at 88% 20%, rgba(255, 255, 255, 0.18), transparent 35%),
    linear-gradient(135deg, #1268E5, #51A2FF);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(22, 119, 255, 0.2);
}

.avatar-button {
  position: relative;
  z-index: 2;
  display: block;
  width: 88rpx;
  height: 88rpx;
  margin: 0;
  padding: 0;
  overflow: visible;
  color: inherit;
  background: transparent;
  border: 0;
  border-radius: 50%;
  line-height: 1;
}

.avatar-button::after {
  display: none;
}

.avatar-shell {
  position: relative;
  display: flex;
  width: 86rpx;
  height: 86rpx;
  padding: 5rpx;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.26);
  border: 2rpx solid rgba(255, 255, 255, 0.55);
  border-radius: 50%;
  box-shadow:
    0 8rpx 20rpx rgba(0, 63, 155, 0.2),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.12);
}

.avatar {
  position: relative;
  z-index: 1;
  display: block;
  width: 76rpx;
  height: 76rpx;
  overflow: hidden;
  background: #FFFFFF;
  border: 3rpx solid #FFFFFF;
  border-radius: 50%;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1268E5;
  background: linear-gradient(145deg, #FFFFFF, #EAF4FF);
}

.avatar-letter {
  font-size: 30rpx;
  font-weight: 600;
}

.avatar-edit-badge {
  position: absolute;
  right: -2rpx;
  bottom: -1rpx;
  display: flex;
  width: 30rpx;
  height: 30rpx;
  align-items: center;
  justify-content: center;
  color: #1677FF;
  background: #FFFFFF;
  border: 3rpx solid #D9ECFF;
  border-radius: 50%;
  box-shadow: 0 4rpx 10rpx rgba(0, 70, 160, 0.2);
}

.avatar-edit-icon {
  color: #1677FF;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 26rpx;
}

.profile-main {
  min-width: 0;
  margin-left: 16rpx;
  flex: 1;
}

.profile-name {
  overflow: hidden;
  font-size: 28rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-id {
  margin-top: 2rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 19rpx;
}

.avatar-hint {
  margin-top: 3rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 17rpx;
}

.safe-tag {
  padding: 5rpx 10rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 999rpx;
  font-size: 17rpx;
}

.compact-card {
  margin-bottom: 14rpx;
  padding: 16rpx 22rpx;
}

.compact-card > .section-title {
  font-size: 29rpx;
  line-height: 38rpx;
}

.compact-card > .section-desc {
  margin-top: 2rpx;
  font-size: 20rpx;
}

.profile-row {
  display: flex;
  min-height: 64rpx;
  align-items: center;
  border-bottom: 1rpx solid #F2F3F5;
}

.row-label {
  color: #4E5969;
}

.row-input {
  margin-left: auto;
  text-align: right;
}

.row-value {
  color: #4E5969;
}

.profile-save {
  height: 62rpx;
  margin-top: 12rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.feedback-heading,
.history-heading,
.history-item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-count {
  color: #86909C;
  font-size: 20rpx;
}

.feedback-input {
  width: 100%;
  height: 150rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  line-height: 1.6;
}

.contact-input {
  height: 68rpx;
  margin-top: 12rpx;
  padding: 0 16rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
}

.feedback-footer {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
}

.char-count {
  color: #C9CDD4;
  font-size: 21rpx;
}

.feedback-btn {
  height: 64rpx;
  margin: 0 0 0 auto;
  padding: 0 26rpx;
  color: #FFFFFF;
  background: #0960D8;
  border-radius: 14rpx;
  font-size: 24rpx;
  line-height: 64rpx;
}

.history-divider {
  margin: 20rpx 0 16rpx;
  border-top: 1rpx solid #F2F3F5;
}

.history-title {
  color: #1D2129;
  font-size: 26rpx;
  font-weight: 600;
}

.history-toggle {
  color: #1677FF;
  font-size: 21rpx;
}

.history-item {
  margin-top: 14rpx;
  padding: 16rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
}

.history-time {
  color: #86909C;
  font-size: 19rpx;
}

.history-status {
  padding: 5rpx 10rpx;
  border-radius: 7rpx;
  font-size: 18rpx;
}

.status-pending {
  color: #D46B08;
  background: #FFF7E6;
}

.status-processing {
  color: #1677FF;
  background: #E8F3FF;
}

.status-resolved {
  color: #389E0D;
  background: #F6FFED;
}

.history-content {
  display: -webkit-box;
  margin-top: 10rpx;
  overflow: hidden;
  color: #4E5969;
  font-size: 22rpx;
  line-height: 1.5;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.history-contact {
  margin-top: 8rpx;
  color: #A9B1BC;
  font-size: 19rpx;
}

.history-empty {
  padding: 28rpx 0 12rpx;
  color: #A9B1BC;
  font-size: 21rpx;
  text-align: center;
}

.health-notice {
  padding: 2rpx 18rpx 20rpx;
  color: #86909C;
  font-size: 21rpx;
  line-height: 1.7;
  text-align: center;
}
