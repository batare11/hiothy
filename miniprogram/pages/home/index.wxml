<view class="page">
  <view class="hero">
    <view class="hero-copy">
      <view class="hero-title">今天感觉怎么样？</view>
      <view wx:if="{{records.length}}" class="hero-latest">
        <text class="hero-latest-label">上次</text>
        <text class="hero-latest-time">{{records[0].compactTime}}</text>
        <text class="hero-latest-pressure">{{records[0].systolic}}/{{records[0].diastolic}}</text>
        <text class="hero-latest-heart">♥ {{records[0].heart_rate || "--"}}</text>
      </view>
      <view wx:else class="hero-desc">规律记录，读懂每一次变化</view>
    </view>
    <view class="hero-badge" bindtap="openHealthRecord">
      <view class="hero-record-icon">
        <view class="hero-record-tab"></view>
        <view class="hero-record-line"></view>
        <view class="hero-record-line short"></view>
      </view>
      <view class="hero-record-copy">
        <view class="hero-record-title">健康档案</view>
        <view class="hero-record-desc">查看记录</view>
      </view>
      <text class="hero-arrow">›</text>
    </view>
  </view>

  <view class="card entry-card">
    <view class="entry-heading">
      <view class="section-title">血压录入</view>
      <view class="section-desc">拍照识别，也可手动填写</view>
    </view>

    <view class="ocr-engine-section">
      <view class="ocr-engine-title">识别方式</view>
      <view class="ocr-engine-options">
        <view
          wx:for="{{ocrEngines}}"
          wx:key="value"
          class="ocr-engine-option {{ocrEngine === item.value ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="selectOcrEngine"
        >
          <view class="ocr-engine-choice">
            <view class="ocr-engine-radio">
              <view wx:if="{{ocrEngine === item.value}}" class="ocr-engine-radio-dot"></view>
            </view>
            <view class="ocr-engine-text">
              <view class="ocr-engine-label">{{item.label}}</view>
              <view class="ocr-engine-desc">{{item.description}}</view>
            </view>
          </view>
          <view wx:if="{{ocrEngine === item.value}}" class="ocr-engine-selected">已选择</view>
        </view>
      </view>
    </view>

    <view class="upload-area" bindtap="chooseImage">
      <image wx:if="{{imagePath}}" class="preview-image" src="{{imagePath}}" mode="aspectFill"></image>
      <view wx:else class="upload-placeholder">
        <view class="camera-icon">＋</view>
        <view class="upload-title">拍照 / 从相册选择</view>
        <view class="upload-tip">请保持屏幕清晰、无反光</view>
      </view>
      <view wx:if="{{ocrLoading}}" class="recognizing-mask">正在识别...</view>
    </view>

    <view wx:if="{{ocrNotice}}" class="ocr-notice">{{ocrNotice}}</view>

    <view class="form-grid">
      <view class="form-item">
        <view class="form-label">高压 <text>mmHg</text></view>
        <input
          class="number-input"
          type="number"
          maxlength="3"
          value="{{form.systolic}}"
          data-field="systolic"
          bindinput="handleInput"
          placeholder="120"
        />
      </view>
      <view class="form-item">
        <view class="form-label">低压 <text>mmHg</text></view>
        <input
          class="number-input"
          type="number"
          maxlength="3"
          value="{{form.diastolic}}"
          data-field="diastolic"
          bindinput="handleInput"
          placeholder="80"
        />
      </view>
      <view class="form-item">
        <view class="form-label">心率 <text>次/分</text></view>
        <input
          class="number-input"
          type="number"
          maxlength="3"
          value="{{form.heartRate}}"
          data-field="heartRate"
          bindinput="handleInput"
          placeholder="72"
        />
      </view>
    </view>

    <view class="form-row">
      <view class="form-label">测量时间</view>
      <picker mode="date" value="{{form.measuredDate}}" bindchange="handleDateChange">
        <view class="date-picker">{{form.measuredDate}} ›</view>
      </picker>
    </view>

    <view class="form-row note-row">
      <view class="form-label">备注</view>
      <input
        class="note-input"
        value="{{form.note}}"
        data-field="note"
        bindinput="handleInput"
        placeholder="如：昨晚熬夜、服药后、头晕等"
      />
    </view>

    <button class="primary-btn submit-btn" loading="{{submitting}}" bindtap="submitRecord">
      确认并保存
    </button>
  </view>
</view>
