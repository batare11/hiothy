.tab-shell {
  position: fixed;
  z-index: 999;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 10rpx 20rpx calc(10rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(22, 119, 255, 0.08);
  box-shadow: 0 -8rpx 28rpx rgba(31, 78, 121, 0.1);
}

.tab-bar {
  display: flex;
  height: 92rpx;
  align-items: center;
  justify-content: space-around;
}

.tab-item {
  position: relative;
  display: flex;
  min-width: 120rpx;
  height: 82rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8A96A6;
  border-radius: 20rpx;
}

.tab-item.active {
  color: #1677FF;
  background: linear-gradient(180deg, #EEF6FF, #E2F0FF);
  transform: translateY(-5rpx);
}

.tab-icon-wrap {
  display: flex;
  width: 42rpx;
  height: 40rpx;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  position: relative;
  width: 38rpx;
  height: 36rpx;
}

.tab-text {
  margin-top: 3rpx;
  font-size: 19rpx;
  font-weight: 500;
  line-height: 26rpx;
}

.tab-item.active .tab-text {
  font-weight: 600;
}

.home-roof {
  position: absolute;
  top: 3rpx;
  left: 7rpx;
  width: 24rpx;
  height: 24rpx;
  border-top: 5rpx solid currentColor;
  border-left: 5rpx solid currentColor;
  transform: rotate(45deg);
  border-radius: 3rpx;
}

.home-body {
  position: absolute;
  right: 6rpx;
  bottom: 2rpx;
  left: 6rpx;
  height: 21rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 2rpx 2rpx 5rpx 5rpx;
}

.chart-icon {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 4rpx;
  padding-bottom: 3rpx;
  border-bottom: 3rpx solid currentColor;
}

.chart-bar {
  width: 7rpx;
  background: currentColor;
  border-radius: 4rpx 4rpx 1rpx 1rpx;
}

.chart-bar.short { height: 13rpx; }
.chart-bar.medium { height: 22rpx; }
.chart-bar.tall { height: 31rpx; }

.message-body {
  position: absolute;
  top: 4rpx;
  right: 2rpx;
  left: 2rpx;
  height: 25rpx;
  border: 4rpx solid currentColor;
  border-radius: 8rpx;
}

.message-tail {
  position: absolute;
  bottom: 2rpx;
  left: 8rpx;
  width: 10rpx;
  height: 10rpx;
  border-bottom: 4rpx solid currentColor;
  border-left: 4rpx solid currentColor;
  transform: skewY(-28deg);
}

.tab-unread-badge {
  position: absolute;
  z-index: 2;
  top: -13rpx;
  left: 25rpx;
  display: flex;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 7rpx;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #F53F3F;
  border: 3rpx solid #FFFFFF;
  border-radius: 999rpx;
  font-size: 16rpx;
  font-weight: 600;
  line-height: 28rpx;
}

.profile-head {
  position: absolute;
  top: 1rpx;
  left: 13rpx;
  width: 13rpx;
  height: 13rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.profile-body {
  position: absolute;
  right: 3rpx;
  bottom: 1rpx;
  left: 3rpx;
  height: 17rpx;
  border: 4rpx solid currentColor;
  border-bottom: 0;
  border-radius: 18rpx 18rpx 0 0;
}
