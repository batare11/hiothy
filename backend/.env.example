APP_NAME=Hiothy Blood Pressure API
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=5000
API_PREFIX=/api/v1

# PostgreSQL：复制本文件为 .env 后填写真实密码。
DATABASE_URL=postgresql+psycopg://blood_pressure:CHANGE_ME@101.42.90.208:5432/blood_pressure

# 多个来源用英文逗号分隔。微信小程序请求不受浏览器 CORS 限制。
ALLOWED_ORIGINS=https://hiothy.cn,http://localhost:5000,http://127.0.0.1:5000

# 上传限制（MB）
MAX_UPLOAD_MB=10

