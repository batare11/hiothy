APP_NAME=Hiothy Blood Pressure API
APP_ENV=production
DEBUG=false
HOST=127.0.0.1
PORT=5000
API_PREFIX=/api/v1

# PostgreSQL：复制本文件为 .env 后填写真实密码。
DATABASE_URL=postgresql+psycopg://blood_pressure:CHANGE_ME@127.0.0.1:5432/blood_pressure

# 多个来源用英文逗号分隔。微信小程序请求不受浏览器 CORS 限制。
ALLOWED_ORIGINS=https://hiothy.cn

# 上传限制（MB）
MAX_UPLOAD_MB=10

# 微信公众平台“开发管理 → 开发设置”中的 AppID 和 AppSecret。
# AppSecret 只能放在服务器，绝不能写入小程序代码。
WECHAT_APP_ID=wxd50ef286dbb80bef
WECHAT_APP_SECRET=replace_with_wechat_app_secret

# 至少 32 个随机字符；可执行 openssl rand -hex 32 生成。
AUTH_TOKEN_SECRET=replace_with_at_least_32_random_characters
AUTH_TOKEN_EXPIRE_DAYS=30

# 可选：GLM 云端 OCR。实际 endpoint/model 以你的 GLM 控制台文档为准。
GLM_OCR_API_KEY=replace_with_glm_api_key
GLM_OCR_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/layout_parsing
GLM_OCR_MODEL=glm-ocr
# 可选：用于将 OCR 原文整理为 JSON；未开通文本模型时留空。
GLM_OCR_STRUCTURED_MODEL=
GLM_OCR_TIMEOUT=60
# 兼容旧部署保留；当前 GLM 调用直接传递 JPEG Base64，不再依赖公网临时图片。
GLM_OCR_PUBLIC_BASE_URL=

# 豆包视觉增强识别。DOUBAO_MODEL 应填写方舟控制台的推理接入点 ID。
DOUBAO_API_KEY=replace_with_ark_api_key
DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_MODEL=replace_with_endpoint_id
DOUBAO_TIMEOUT=60

# DeepSeek V4 Pro 健康档案分析。模型固定为 deepseek-v4-pro。
DEEPSEEK_API_KEY=replace_with_deepseek_api_key
DEEPSEEK_ENDPOINT=https://api.deepseek.com/chat/completions
DEEPSEEK_TIMEOUT=90

# auto 模式中，RapidOCR 达到此置信度且三项完整时不再调用云端。
OCR_AUTO_MIN_CONFIDENCE=0.85
OCR_TEMP_DIR=uploads/ocr-temp
OCR_TEMP_FILE_TTL=300

